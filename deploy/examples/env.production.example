# Dualens production environment example.
# Copy to a protected secret store or /etc/dualens/dualens.env.
# Do not commit real values.

NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Provider secrets. Rotate before every production redeploy if exposure is suspected.
DEEPSEEK_API_KEY=replace-with-production-secret
DEEPSEEK_BASE_URL=https://api.deepseek.com
TAVILY_API_KEY=replace-with-production-secret

# Optional OpenAI-compatible fallback; prefer provider-specific names in production.
# OPENAI_API_KEY=replace-with-production-secret
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_COMPATIBLE_API_KEY=replace-with-production-secret
# OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1

# Session creation controls.
# Keep anonymous sessions disabled unless the deployment is intentionally public.
DUALENS_ALLOW_ANONYMOUS_SESSIONS=0
DUALENS_SESSION_API_TOKEN=replace-with-long-random-token
DUALENS_SESSION_OWNER_SECRET=replace-with-long-random-cookie-signing-secret
DUALENS_SESSION_RATE_LIMIT_MAX=30

# Public GitHub metadata. These are safe to expose to the browser.
NEXT_PUBLIC_GITHUB_OWNER=replace-with-public-owner
NEXT_PUBLIC_GITHUB_REPO=replace-with-public-repo
NEXT_PUBLIC_GITHUB_REPO_URL=https://github.com/replace-with-public-owner/replace-with-public-repo

# Must remain unset in production:
# DEBUG=
# MOCK_RESEARCH=
# NODE_OPTIONS=--inspect
