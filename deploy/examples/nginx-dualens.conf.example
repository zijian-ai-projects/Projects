# Nginx reverse proxy example for Dualens.
# Draft only. Replace domain names, certificate paths, and access-control policy.

limit_req_zone $binary_remote_addr zone=dualens_api:10m rate=60r/m;
limit_req_zone $binary_remote_addr zone=dualens_session:10m rate=10r/m;
limit_req_status 429;

upstream dualens_next {
    server 127.0.0.1:3000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name dualens.example.com;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/letsencrypt;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name dualens.example.com;

    ssl_certificate /etc/letsencrypt/live/dualens.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/dualens.example.com/privkey.pem;
    ssl_session_timeout 1d;
    ssl_session_cache shared:dualens_tls:10m;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    client_max_body_size 1m;
    server_tokens off;

    access_log /var/log/nginx/dualens.access.log;
    error_log /var/log/nginx/dualens.error.log warn;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()" always;

    # Start CSP in Report-Only mode. Enforce only after checking browser reports.
    add_header Content-Security-Policy-Report-Only "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; img-src 'self' data: https:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self'; form-action 'self'; upgrade-insecure-requests" always;

    # Deny accidental exposure of local files and secret paths.
    location ~ /\.(?!well-known) {
        deny all;
    }

    location ~* /(package\.json|pnpm-lock\.yaml|tsconfig\.json|next\.config\.ts|SECURITY_AUDIT\.md|FIX_PLAN\.md|DEPLOY_HARDENING\.md)$ {
        return 404;
    }

    location ~* \.(env|pem|key|crt|sql|sqlite|bak|backup|old|swp)$ {
        return 404;
    }

    # Current app has no upload endpoint. Keep this closed unless an upload feature is designed and hardened.
    location ^~ /uploads/ {
        return 404;
    }

    # Optional management-page gate. Replace with SSO/auth_request/VPN/IP allowlist for production.
    # location ~ ^/(app|providers|search-engines|settings|history)(/|$) {
    #     auth_basic "Dualens restricted area";
    #     auth_basic_user_file /etc/nginx/dualens.htpasswd;
    #     proxy_pass http://dualens_next;
    #     include /etc/nginx/snippets/dualens_proxy_params.conf;
    # }

    location ^~ /api/session {
        limit_req zone=dualens_session burst=20 nodelay;
        proxy_pass http://dualens_next;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Request-ID $request_id;
        proxy_read_timeout 90s;
        proxy_send_timeout 90s;
    }

    location ^~ /api/ {
        limit_req zone=dualens_api burst=120 nodelay;
        proxy_pass http://dualens_next;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Request-ID $request_id;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }

    location / {
        proxy_pass http://dualens_next;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Request-ID $request_id;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }
}
